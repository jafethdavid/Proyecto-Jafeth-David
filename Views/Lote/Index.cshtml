@model List<IS_161_Proyecto_Grupo2.Models.Lote>
@{
    ViewData["Title"] = "Lotes";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-collection me-2"></i>Control de Lotes</h2>
    <a href="/Producto" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a Productos
    </a>
</div>

<div class="card shadow mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-bold">Filtrar por Producto</label>
                <select name="idProducto" class="form-select">
                    <option value="">Todos los productos</option>
                    @foreach (var prod in ViewBag.Productos ?? new List<IS_161_Proyecto_Grupo2.Models.Producto>())
                    {
                        <option value="@prod.IdProducto"
                                selected="@(ViewBag.IdProductoFiltro != null &&
                                                                        ViewBag.IdProductoFiltro == prod.IdProducto)">
                        @prod.NombreProducto
                    </option>
                                        }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
            </div>
            <div class="col-md-3">
                <a href="/Lote/Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                No hay lotes registrados.
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Código Lote</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Unidades</th>
                        <th>Fecha Ingreso</th>
                        <th>Fecha Vencimiento</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center @(!item.Estatus ? "table-secondary" :
                                                                              item.EstaVencido() ? "table-danger" :
                                                                              item.DiasParaVencer() <= 30 ? "table-warning" : "")">
                    <td>@item.IdLote</td>
                    <td>
                        <span class="badge bg-dark">@item.CodigoLote</span>
                    </td>
                    <td class="text-start">@item.NombreProducto</td>
                    <td>
                        <span class="badge bg-info text-dark">
                            @item.Cantidad
                        </span>
                    </td>
                    <td>@item.Unidades</td>
                    <td>@item.FechaIngreso.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (item.FechaVencimiento == null)
                                {
                                    <span class="text-muted">No aplica</span>
                                }
                                else if (item.EstaVencido())
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        Vencido (@item.FechaVencimiento.Value.ToString("dd/MM/yyyy"))
                                    </span>
                                }
                                else if (item.DiasParaVencer() <= 30)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock me-1"></i>
                                        Vence en @item.DiasParaVencer() días
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success">
                                        @item.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                            </td>
                            <td>
                                @if (item.Estatus)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a href="/Lote/Edit/@item.IdLote"
                                   class="btn btn-warning btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (!item.Estatus)
                                {
                                    <button class="btn btn-danger btn-sm disabled"
                                            title="Ya está inactivo" disabled>
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else if (item.Cantidad > 0)
                                {
                                    <a href="/Lote/Delete/@item.IdLote"
                                       class="btn btn-danger btn-sm" title="Desactivar"
                                       onclick="return confirm('Este lote tiene @item.Cantidad unidades disponibles. ¿Seguro que deseas desactivarlo? El stock se perderá.')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="/Lote/Delete/@item.IdLote"
                                       class="btn btn-danger btn-sm" title="Desactivar"
                                       onclick="return confirm('¿Desactivar el lote @(item.CodigoLote)?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>