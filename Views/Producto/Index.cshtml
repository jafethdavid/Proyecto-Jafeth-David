@model List<IS_161_Proyecto_Grupo2.Models.Producto>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lista de Productos</h2>
    <div class="d-flex align-items-center gap-2">
        <a href="/Categoria" class="btn btn-primary">
            <i class="bi bi-tags"></i> Categorías
        </a>
        <a href="/Producto/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Producto
        </a>
    </div>
</div>

<div class="card shadow">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                No hay productos registrados. <a href="/Producto/Create">Crear el primero</a>
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Subcategoría</th>
                        <th>Precio Venta</th>
                        <th>Impuesto</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th>Agregar Lote</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center @(!item.Estado ? "table-secondary" : "")">
                            <td>@item.IdProducto</td>
                            <td>
                                <small class="text-muted">@item.CodigoProducto</small>
                            </td>
                            <td class="text-start">@item.NombreProducto</td>
                            <td>@item.NombreCategoria</td>
                            <td>@item.NombreSubcategoria</td>
                            <td>L. @item.PrecioVenta?.ToString("N2")</td>
                            <td>@item.Impuesto %</td>
                            <td>
                                @if (item.BajoStock())
                                {
                                    <span class="badge bg-danger"
                                          title="Stock bajo mínimo (@(item.StockMinimo))">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        @item.StockTotal()
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @item.StockTotal()
                                    </span>
                                }
                            </td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                @if (!item.Estado)
                                {
                                    <button class="btn btn-sm btn-success disabled"
                                            title="Producto inactivo" disabled>
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                                else
                                {
                                    <a href="/Lote/Create?idProducto=@item.IdProducto"
                                       class="btn btn-sm btn-success" title="Agregar Lote">
                                        <i class="bi bi-plus-lg"></i>
                                    </a>
                                }
                            </td>
                            <td>
                                <a href="/Producto/Edit/@item.IdProducto"
                                   class="btn btn-warning btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (!item.Estado)
                                {
                                    <button class="btn btn-danger btn-sm disabled"
                                            title="Ya está inactivo" disabled>
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                @{ }
                                else if (IS_161_Proyecto_Grupo2.Data.BaseDatosMemoria
                                .Lotes.Any(l => l.IdProducto == item.IdProducto
                                && l.Estatus && l.Cantidad > 0))
                                {
                                <button class="btn btn-danger btn-sm disabled"
                                        title="Tiene lotes activos con stock" disabled>
                                    <i class="bi bi-trash"></i>
                                </button>
                                }
                                else
                                {
                                <a href="/Producto/Delete/@item.IdProducto"
                                   class="btn btn-danger btn-sm" title="Desactivar"
                                   onclick="return confirm('¿Desactivar @(item.NombreProducto)?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>