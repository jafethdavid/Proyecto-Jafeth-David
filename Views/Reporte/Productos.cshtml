@model List<IS_161_Proyecto_Grupo2.Models.Producto>
@using IS_161_Proyecto_Grupo2.Models
@{
    ViewData["Title"] = "Reporte de Productos";
    var productosBajoStock = ViewBag.ProductosBajoStock as List<Producto>;

    var estadoFiltro = Context.Request.Query["estado"].ToString();
    var stockFiltro = Context.Request.Query["stock"].ToString();

    var lista = Model.AsEnumerable();

    if (estadoFiltro == "activo")
        lista = lista.Where(p => p.Estado);
    else if (estadoFiltro == "inactivo")
        lista = lista.Where(p => !p.Estado);

    if (stockFiltro == "bajo")
        lista = lista.Where(p => p.BajoStock());
    else if (stockFiltro == "sinstock")
        lista = lista.Where(p => p.StockTotal() == 0);

    var productos = lista.ToList();
}

<h2 class="mb-4">
    <i class="bi bi-box-seam me-2"></i>Reporte de Productos
</h2>

@if (productosBajoStock != null && productosBajoStock.Any())
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>¡Atención!</strong> Hay @productosBajoStock.Count producto(s)
        con stock por debajo del mínimo.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold">Estado</label>
                <select name="estado" class="form-select">
                    <option value="" selected="@(estadoFiltro == "")">Todos</option>
                    <option value="activo" selected="@(estadoFiltro == "activo")">Solo activos</option>
                    <option value="inactivo" selected="@(estadoFiltro == "inactivo")">Solo inactivos</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Stock</label>
                <select name="stock" class="form-select">
                    <option value="" selected="@(stockFiltro == "")">Todos</option>
                    <option value="bajo" selected="@(stockFiltro == "bajo")">Bajo mínimo</option>
                    <option value="sinstock" selected="@(stockFiltro == "sinstock")">Sin stock</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a href="/Reporte/Productos" class="btn btn-outline-secondary w-100 mt-1">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card border-primary text-center">
            <div class="card-body">
                <h5 class="text-primary"><i class="bi bi-box-seam me-1"></i>Total</h5>
                <h3>@productos.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success text-center">
            <div class="card-body">
                <h5 class="text-success"><i class="bi bi-check-circle me-1"></i>Activos</h5>
                <h3>@productos.Count(p => p.Estado)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-secondary text-center">
            <div class="card-body">
                <h5 class="text-secondary"><i class="bi bi-x-circle me-1"></i>Inactivos</h5>
                <h3>@productos.Count(p => !p.Estado)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger text-center">
            <div class="card-body">
                <h5 class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Bajo Stock</h5>
                <h3>@(productosBajoStock?.Count ?? 0)</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow">
    <div class="card-body">
        @if (!productos.Any())
        {
            <div class="alert alert-info text-center">
                No hay productos que coincidan con los filtros.
            </div>
        }
        else
        {
            <div class="d-flex justify-content-end gap-2 mb-3">
                <button onclick="exportarExcel()" class="btn btn-success">
                    <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
                </button>
                <button onclick="exportarPDF()" class="btn btn-danger">
                    <i class="bi bi-file-earmark-pdf me-1"></i>Exportar PDF
                </button>
            </div>

            <table class="table table-bordered table-hover align-middle text-center"
                   id="tablaProductos">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Subcategoría</th>
                        <th>Precio Costo</th>
                        <th>Precio Venta</th>
                        <th>Impuesto</th>
                        <th>Stock Total</th>
                        <th>Stock Mínimo</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in productos)
                    {
                        <tr class="@(!item.Estado ? "table-secondary" :
                                                                  item.BajoStock() ? "table-warning" : "")">
                    <td>@item.IdProducto</td>
                    <td><small class="text-muted">@item.CodigoProducto</small></td>
                    <td class="text-start">@item.NombreProducto</td>
                    <td>@item.NombreCategoria</td>
                    <td>@item.NombreSubcategoria</td>
                    <td>L. @item.PrecioCosto?.ToString("N2")</td>
                    <td>L. @item.PrecioVenta?.ToString("N2")</td>
                    <td>@item.Impuesto %</td>
                    <td>
                        @if (item.BajoStock())
                                {
                                    <span class="badge bg-danger">@item.StockTotal()</span>
                                }
                                else if (item.StockTotal() == 0)
                                {
                                    <span class="badge bg-warning text-dark">Sin stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.StockTotal()</span>
                                }
                            </td>
                            <td>@item.StockMinimo</td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row justify-content-end mt-2">
                <div class="col-md-4">
                    <table class="table table-borderless text-end">
                        <tr class="table-dark">
                            <td class="fw-bold">Stock total en inventario:</td>
                            <td class="fw-bold">@productos.Sum(p => p.StockTotal()) unidades</td>
                        </tr>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script>

        function exportarExcel() {
            const tabla   = document.getElementById('tablaProductos');
            const wb      = XLSX.utils.book_new();
            const ws      = XLSX.utils.table_to_sheet(tabla);
            XLSX.utils.book_append_sheet(wb, ws, 'Productos');
            XLSX.writeFile(wb, 'Reporte_Productos.xlsx');
        }

        function exportarPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('landscape', 'mm', 'a4');

            doc.setFontSize(16);
            doc.text('Reporte de Productos - MercaditoUPH', 14, 15);
            doc.setFontSize(10);
            doc.text(`Generado: ${new Date().toLocaleDateString('es-HN')}`, 14, 22);

            const tabla    = document.getElementById('tablaProductos');
            const headers  = [];
            const rows     = [];

            tabla.querySelectorAll('thead tr th').forEach(th => {
                headers.push(th.innerText.trim());
            });

            tabla.querySelectorAll('tbody tr').forEach(tr => {
                const fila = [];
                tr.querySelectorAll('td').forEach(td => {
                    fila.push(td.innerText.trim());
                });
                rows.push(fila);
            });

            doc.autoTable({
                head:       [headers],
                body:       rows,
                startY:     28,
                styles:     { fontSize: 8, cellPadding: 2 },
                headStyles: { fillColor: [33, 37, 41], textColor: 255 },
                alternateRowStyles: { fillColor: [245, 245, 245] }
            });

            doc.save('Reporte_Productos.pdf');
        }
    </script>
}