@model IS_161_Proyecto_Grupo2.Models.Factura
@using IS_161_Proyecto_Grupo2.Models
@{
    ViewData["Title"] = "Detalle de Factura";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="bi bi-receipt me-2"></i>

        Detalle de Factura FAC-@Model.IdFactura.ToString("D6")
    </h2>
    <a href="/Reporte/Ventas" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow">
    <div class="card-body">

        <div class="row mb-4">
            <div class="col-md-6">
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold">Factura #:</td>
                        <td>FAC-@Model.IdFactura.ToString("D6")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Fecha:</td>
                        <td>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Cliente:</td>

                        <td>@(Model.Cliente ?? "Consumidor Final")</td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6 text-end">
 
                <h5>
                    Estado:
                    @switch (Model.EstatusFactura)
                    {
                        case EnumEstatusFactura.Creada:
                            <span class="badge bg-info fs-6">Creada</span>
                            break;
                        case EnumEstatusFactura.EnProceso:
                            <span class="badge bg-warning text-dark fs-6">En Proceso</span>
                            break;
                        case EnumEstatusFactura.Procesada:
                            <span class="badge bg-success fs-6">Procesada</span>
                            break;
                        case EnumEstatusFactura.Cancelada:
                            <span class="badge bg-secondary fs-6">Cancelada</span>
                            break;
                    }
                </h5>
            </div>
        </div>

        <hr />


        <table class="table table-bordered align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio Unitario</th>
                    <th>Subtotal Línea</th>  
                </tr>
            </thead>
            <tbody>
                @{
                    int linea = 1;
                }
                @foreach (var detalle in Model.Detalles)
                {
                    <tr>
                        <td>@linea</td>

                        <td class="text-start">@detalle.NombreProducto</td>
                        <td>@detalle.Cantidad</td>
                        <td>L. @detalle.PrecioUnitario.ToString("N2")</td>
     
                        <td>L. @detalle.SubtotalLinea.ToString("N2")</td>
                    </tr>
                    linea++;
                }
            </tbody>
        </table>

        <div class="row justify-content-end">
            <div class="col-md-4">
                <table class="table table-borderless text-end">
                    <tr>
                        <td class="fw-bold">Subtotal:</td>
                        <td>L. @Model.Subtotal.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">IVA (15%):</td>
                        <td>L. @Model.IVA.ToString("N2")</td>
                    </tr>
                    <tr class="table-dark">
                        <td class="fw-bold fs-5">Total:</td>
                        <td class="fw-bold fs-5">L. @Model.Total.ToString("N2")</td>
                    </tr>
                </table>
            </div>
        </div>

        <hr />

        <div class="d-flex justify-content-between">
            <a href="/Reporte/Ventas" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>

            <button onclick="window.print()" class="btn btn-primary">
                <i class="bi bi-printer me-1"></i>Imprimir
            </button>
        </div>

    </div>
</div>