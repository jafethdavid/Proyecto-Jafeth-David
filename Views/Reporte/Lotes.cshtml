@model List<IS_161_Proyecto_Grupo2.Models.Lote>
@using IS_161_Proyecto_Grupo2.Models
@{
    ViewData["Title"] = "Reporte de Lotes";
    var lotesProximosVencer = ViewBag.LotesProximosVencer as List<Lote>;

    var estadoFiltro = Context.Request.Query["estado"].ToString();
    var vencimientoFiltro = Context.Request.Query["vencimiento"].ToString();

    var lista = Model.AsEnumerable();

    if (estadoFiltro == "activo")
        lista = lista.Where(l => l.Estatus && !l.EstaVencido() && l.Cantidad > 0);
    else if (estadoFiltro == "inactivo")
        lista = lista.Where(l => !l.Estatus);
    else if (estadoFiltro == "agotado")
        lista = lista.Where(l => l.Cantidad == 0 && l.Estatus);

    if (vencimientoFiltro == "vencido")
        lista = lista.Where(l => l.EstaVencido());
    else if (vencimientoFiltro == "por_vencer")
        lista = lista.Where(l => !l.EstaVencido() &&
                                  l.FechaVencimiento.HasValue &&
                                  l.DiasParaVencer() <= 30);
    else if (vencimientoFiltro == "sin_vencimiento")
        lista = lista.Where(l => l.FechaVencimiento == null);

    var lotes = lista.ToList();
}

<h2 class="mb-4">
    <i class="bi bi-collection me-2"></i>Reporte de Lotes por Producto
</h2>

@if (lotesProximosVencer != null && lotesProximosVencer.Any())
{
    <div class="alert alert-warning alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>¡Atención!</strong> Hay @lotesProximosVencer.Count lote(s)
        próximos a vencer en los próximos 30 días.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold">Estado</label>
                <select name="estado" class="form-select">
                    <option value="" selected="@(estadoFiltro == "")">Todos</option>
                    <option value="activo" selected="@(estadoFiltro == "activo")">Activos</option>
                    <option value="inactivo" selected="@(estadoFiltro == "inactivo")">Inactivos</option>
                    <option value="agotado" selected="@(estadoFiltro == "agotado")">Agotados</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Vencimiento</label>
                <select name="vencimiento" class="form-select">
                    <option value="" selected="@(vencimientoFiltro == "")">Todos</option>
                    <option value="vencido" selected="@(vencimientoFiltro == "vencido")">Vencidos</option>
                    <option value="por_vencer" selected="@(vencimientoFiltro == "por_vencer")">Por vencer (30 días)</option>
                    <option value="sin_vencimiento" selected="@(vencimientoFiltro == "sin_vencimiento")">Sin vencimiento</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a href="/Reporte/Lotes" class="btn btn-outline-secondary w-100 mt-1">
                    <i class="bi bi-x-circle me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card border-primary text-center">
            <div class="card-body">
                <h5 class="text-primary"><i class="bi bi-collection me-1"></i>Total Lotes</h5>
                <h3>@lotes.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success text-center">
            <div class="card-body">
                <h5 class="text-success"><i class="bi bi-check-circle me-1"></i>Activos</h5>
                <h3>@lotes.Count(l => l.Estatus && !l.EstaVencido())</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger text-center">
            <div class="card-body">
                <h5 class="text-danger"><i class="bi bi-x-circle me-1"></i>Vencidos</h5>
                <h3>@lotes.Count(l => l.EstaVencido())</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning text-center">
            <div class="card-body">
                <h5 class="text-warning"><i class="bi bi-clock me-1"></i>Por Vencer</h5>
                <h3>@(lotesProximosVencer?.Count ?? 0)</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow">
    <div class="card-body">
        @if (!lotes.Any())
        {
            <div class="alert alert-info text-center">
                No hay lotes que coincidan con los filtros.
            </div>
        }
        else
        {
            <div class="d-flex justify-content-end gap-2 mb-3">
                <button onclick="exportarExcel()" class="btn btn-success">
                    <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
                </button>
                <button onclick="exportarPDF()" class="btn btn-danger">
                    <i class="bi bi-file-earmark-pdf me-1"></i>Exportar PDF
                </button>
            </div>

            <table class="table table-bordered table-hover align-middle text-center"
                   id="tablaLotes">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Código Lote</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Unidades</th>
                        <th>Fecha Ingreso</th>
                        <th>Fecha Vencimiento</th>
                        <th>Días Restantes</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lote in lotes)
                    {
                        <tr class="@(!lote.Estatus ? "table-secondary" :
                                                                  lote.EstaVencido() ? "table-danger" :
                                                                  lote.DiasParaVencer() <= 30 ? "table-warning" : "")">
                    <td>@lote.IdLote</td>
                    <td><span class="badge bg-dark">@lote.CodigoLote</span></td>
                    <td class="text-start">@lote.NombreProducto</td>
                    <td>
                        @if (lote.Cantidad == 0)
                                {
                                    <span class="badge bg-warning text-dark">Agotado</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@lote.Cantidad</span>
                                }
                            </td>
                            <td>@lote.Unidades</td>
                            <td>@lote.FechaIngreso.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (lote.FechaVencimiento == null)
                                {
                                    <span class="text-muted">No aplica</span>
                                }
                                else if (lote.EstaVencido())
                                {
                                    <span class="text-danger fw-bold">
                                        @lote.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                                else
                                {
                                    @lote.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                }
                            </td>
                            <td>
                                @if (lote.FechaVencimiento == null)
                                {
                                    <span class="text-muted">-</span>
                                }
                                else if (lote.EstaVencido())
                                {
                                    <span class="badge bg-danger">Vencido</span>
                                }
                                else if (lote.DiasParaVencer() <= 30)
                                {
                                    <span class="badge bg-warning text-dark">
                                        @lote.DiasParaVencer() días
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success">@lote.DiasParaVencer() días</span>
                                }
                            </td>
                            <td>
                                @if (!lote.Estatus)
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                                else if (lote.EstaVencido())
                                {
                                    <span class="badge bg-danger">Vencido</span>
                                }
                                else if (lote.Cantidad == 0)
                                {
                                    <span class="badge bg-warning text-dark">Agotado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row justify-content-end mt-2">
                <div class="col-md-4">
                    <table class="table table-borderless text-end">
                        <tr class="table-dark">
                            <td class="fw-bold">Total unidades en lotes activos:</td>
                            @(..)
                            <td class="fw-bold">
                                @(lotes.Where(l => l.Estatus && !l.EstaVencido()).Sum(l => l.Cantidad)) unidades
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script>
        function exportarExcel() {
            const tabla = document.getElementById('tablaLotes');
            const wb    = XLSX.utils.book_new();
            const ws    = XLSX.utils.table_to_sheet(tabla);
            XLSX.utils.book_append_sheet(wb, ws, 'Lotes');
            XLSX.writeFile(wb, 'Reporte_Lotes.xlsx');
        }

        function exportarPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('landscape', 'mm', 'a4');

            doc.setFontSize(16);
            doc.text('Reporte de Lotes - MercaditoUPH', 14, 15);
            doc.setFontSize(10);
            doc.text(`Generado: ${new Date().toLocaleDateString('es-HN')}`, 14, 22);

            const tabla   = document.getElementById('tablaLotes');
            const headers = [];
            const rows    = [];

            tabla.querySelectorAll('thead tr th').forEach(th => {
                headers.push(th.innerText.trim());
            });

            tabla.querySelectorAll('tbody tr').forEach(tr => {
                const fila = [];
                tr.querySelectorAll('td').forEach(td => {
                    fila.push(td.innerText.trim());
                });
                rows.push(fila);
            });

            doc.autoTable({
                head:       [headers],
                body:       rows,
                startY:     28,
                styles:     { fontSize: 8, cellPadding: 2 },
                headStyles: { fillColor: [33, 37, 41], textColor: 255 },
                alternateRowStyles: { fillColor: [245, 245, 245] }
            });

            doc.save('Reporte_Lotes.pdf');
        }
    </script>
}