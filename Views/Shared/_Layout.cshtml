<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>SISTEMA DE VENTAS GRUPO 2</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        .fondo-sistema {
            margin-top: 30px;
            margin-bottom: 40px;
        }

        .navbar-brand img {
            height: 50px;
            width: auto;
            object-fit: contain;
        }

        .contenido-principal {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        .nav-active {
            background-color: rgba(255,255,255,0.15) !important;
            border-radius: 6px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/img/Logo2.png" class="me-2">
                Mercadito UPH
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMenu">
                <div class="ms-auto d-flex gap-2 align-items-center">

                    <a class="btn btn-outline-light" href="/Categoria">
                        <i class="bi bi-tags me-1"></i>Categorías
                    </a>

                    <a class="btn btn-outline-light" href="/Producto">
                        <i class="bi bi-box-seam me-1"></i>Productos
                    </a>

                    <a class="btn btn-outline-light" href="/Lote/Index">
                        <i class="bi bi-collection me-1"></i>Lotes
                    </a>

                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle"
                                data-bs-toggle="dropdown">
                            <i class="bi bi-cart-check me-1"></i>Ventas
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="/Venta/Create">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Nueva Venta
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Venta/Index">
                                    <i class="bi bi-receipt me-2"></i>
                                    Historial de Ventas
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle"
                                data-bs-toggle="dropdown">
                            <i class="bi bi-bar-chart-line me-1"></i>Reportes
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="/Reporte/Productos">
                                    <i class="bi bi-box-seam me-2"></i>
                                    Reporte de Productos
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Reporte/Lotes">
                                    <i class="bi bi-collection me-2"></i>
                                    Lotes por Producto
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Reporte/Movimientos">
                                    <i class="bi bi-arrow-left-right me-2"></i>
                                    Movimientos de Inventario
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Reporte/Ventas">
                                    <i class="bi bi-cash-coin me-2"></i>
                                    Reporte de Ventas
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <div class="fondo-sistema">
        <div class="container">
            <div class="contenido-principal">
                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-4">
        <small>
            <i class="bi bi-shop me-1"></i>
            Mercadito UPH &copy; @DateTime.Now.Year —
            Sistema de Punto de Venta | Grupo 2
        </small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>