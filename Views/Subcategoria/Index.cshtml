@model List<IS_161_Proyecto_Grupo2.Models.Subcategoria>
@{
    ViewData["Title"] = "Subcategorías";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3 me-2"></i>Subcategorías</h2>
    <a href="/Subcategoria/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nueva Subcategoría
    </a>
</div>

<div class="card shadow">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                No hay subcategorías registradas.
                <a href="/Subcategoria/Create">Crear la primera</a>
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th>Productos</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center @(!item.Estado ? "table-secondary" : "")">
                            <td>@item.IdSubcategoria</td>
                            <td>@item.Nombre</td>
                            <td>
                                <span class="badge bg-primary">
                                    @item.NombreCategoria
                                </span>
                            </td>
                            <td class="text-start">
                                <small class="text-muted">
                                    @(item.Descripcion ?? "-")
                                </small>
                            </td>

                            <!-- ── CORREGIDO: inline sin @{ } ─── -->
                            <td>
                                @if (IS_161_Proyecto_Grupo2.Data.BaseDatosMemoria
                                                        .Productos.Any(p => p.IdSubcategoria == item.IdSubcategoria
                                                        && p.Estado))
                                {
                                    <span class="badge bg-info text-dark"
                                          title="Tiene productos activos — no se puede desactivar">
                                        @(IS_161_Proyecto_Grupo2.Data.BaseDatosMemoria
                                                                    .Productos.Count(p => p.IdSubcategoria == item.IdSubcategoria
                                                                    && p.Estado)) activo(s)
                        </span>
                                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>

                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td>
                                <a href="/Subcategoria/Edit/@item.IdSubcategoria"
                                   class="btn btn-warning btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (!item.Estado)
                                {
                                    <button class="btn btn-danger btn-sm disabled"
                                            title="Ya está inactiva" disabled>
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                 @{ }
                                else if (IS_161_Proyecto_Grupo2.Data.BaseDatosMemoria
                                .Productos.Any(p => p.IdSubcategoria == item.IdSubcategoria
                                && p.Estado))
                                {
                                <button class="btn btn-danger btn-sm disabled"
                                        title="Tiene productos activos" disabled>
                                    <i class="bi bi-trash"></i>
                                </button>
                                }
                                else
                                {
                                <a href="/Subcategoria/Delete/@item.IdSubcategoria"
                                   class="btn btn-danger btn-sm" title="Desactivar"
                                   onclick="return confirm('¿Desactivar @(item.Nombre)?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>